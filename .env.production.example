# Copy to .env.production before: npm run build
# Use the SAME public hostname you put in DNS and nginx (TLS required; no ALLOW_INSECURE for real deploy).
#
# WebSocket URL must match nginx location /ws (proxy to C++ on 127.0.0.1:12346).
VITE_WS_URL=wss://chat.example.com/ws
#
# Media API is proxied under the same host at /media/ (see deploy/nginx-chat-https.conf).
VITE_MEDIA_BASE=https://chat.example.com

# Do NOT set this for public HTTPS deploy:
# ALLOW_INSECURE_PROD_BUILD=true
