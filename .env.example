# Copy to .env.production for local production builds, or set these in CI / Netlify / etc.
# Only VITE_* keys are exposed to the browser.

# WebSocket endpoint for the C++ chat server (use wss:// in production).
VITE_WS_URL=wss://chat.example.com/ws

# Base URL for the media HTTP service (uploads, static media). No trailing slash.
VITE_MEDIA_BASE=https://media.example.com

# Optional: only for `npm run build` when you intentionally use ws/http (e.g. local lab).
# Do not enable for real production deploys.
# ALLOW_INSECURE_PROD_BUILD=true
